# =====================================================
# Danish Hanif Hair Lounge — Environment Variables
# Copy this file to `.env.local` for local dev.
# Set the same vars in Vercel Project Settings.
# =====================================================

# Production site URL (no trailing slash). Used for OG, sitemap, schema.
NEXT_PUBLIC_SITE_URL=https://www.danishhanifhairlounge.com

# Optional analytics — set in Vercel, do not commit values.
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTM_ID=

